{
    "contactInfo": {
        "type": "section",
        "formName": "Contact Info",
        "repeatable": false,
        "fieldsets": {
            "main": {
                "repeatable": false,
                "fieldsetName": "contactInfoFieldset",
                "Inputs": {
                    "firstname": {
                        "type": "text",
                        "label": "First Name:"
                    },
                    "lastName": {
                        "type": "text",
                        "label": "Last Name:"
                    },
                    "phone": {
                        "type": "tel",
                        "pattern": "[0-9]{3}-[0-9]{3}-[0-9]{4}",
                        "placeholder": "123-456-7890",
                        "label": "Phone:"
                    },
                    "email": {
                        "type": "email",
                        "label": "Email:"
                    },
                    "personalWebsite": {
                        "type": "url",
                        "label": "Website:"
                    }

                }

            }
        }
    }
}
